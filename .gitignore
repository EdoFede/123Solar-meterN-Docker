# Environment files (never commit real secrets/config)
.env

# Local build artifacts
build_tmp/
*.log

# App code lives in a Docker-managed volume (populated at first boot by
# php/install-apps.sh), never in the repo.
#
# config/ and data/ are host bind-mounts: keep the directory structure
# (.gitkeep) but ignore the runtime content (user config, .htpasswd, RRD DBs…).
/config/*/*
!/config/*/.gitkeep
/data/*/*
!/data/*/.gitkeep

# OS / editor cruft
.DS_Store
*.swp
