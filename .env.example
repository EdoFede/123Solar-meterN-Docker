# --- 123Solar + meterN (Docker) — example environment variables ---
# Copy this file to `.env` and adjust the values:  cp .env.example .env

# HTTP port exposed by the web container (nginx)
HTTP_PORT=8080

# Container timezone
TZ=Europe/Rome

# RS485 serial device passed to the php container (pooler485)
SERIAL_DEVICE=/dev/ttyUSB0

# Automatically re-check the apps' releases at every boot (true/false).
# When false, the apps are installed only once (first boot / empty volume).
AUTO_UPDATE=false

# Run the polling bootstrap (boot123s.php / bootmn.php) at startup (true/false)
POLL_BOOTSTRAP=true

# --- Pinned application versions ---
# Used by app/install-apps.sh to download reproducible releases.
# "latest" = latest release available on GitHub.
SOLAR123_VERSION=latest
METERN_VERSION=latest
