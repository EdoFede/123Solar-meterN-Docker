# --- 123Solar + meterN (Docker) — variabili d'ambiente d'esempio ---
# Copia questo file in `.env` e adatta i valori:  cp .env.example .env

# Porta HTTP esposta dal container web (nginx)
HTTP_PORT=8080

# Timezone del container
TZ=Europe/Rome

# Device seriale RS485 passato al container php (pooler485)
SERIAL_DEVICE=/dev/ttyUSB0

# Aggiornamento automatico delle app al boot (true/false)
AUTO_UPDATE=false

# --- Versioni pinnate delle applicazioni ---
# Usate da app/install-apps.sh per scaricare release riproducibili.
# "latest" = ultima release disponibile su GitHub.
SOLAR123_VERSION=latest
METERN_VERSION=latest
